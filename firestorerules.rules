rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }
    function isManager() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager','superadmin'];
    }
    function isSuperAdmin() {
      return isAdmin() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superadmin';
    }
    function isTeamManager(teamId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.managerId == request.auth.uid;
    }
    function isTeamMember(teamId) {
      return isAuthenticated() && (
        isTeamManager(teamId) ||
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds
      );
    }

    // ── /users/{uid} ──────────────────────────────────
    match /users/{uid} {
      // Users can only read/write their own profile
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.auth.uid == uid;
      allow update: if isOwner(uid) && 
        // Prevent users from escalating their own role
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || 
        isAdmin();
      allow delete: if isOwner(uid) || isSuperAdmin();
    }

    // ── /teams/{teamId} ───────────────────────────────
    match /teams/{teamId} {
      // Anyone authenticated can read teams (to join by invite code)
      allow read:   if isAuthenticated();
      // Only managers can create teams
      allow create: if isAuthenticated() && 
        request.resource.data.managerId == request.auth.uid;
      // Only the team's manager or admin can update/delete
      allow update: if isTeamManager(teamId) || isAdmin();
      allow delete: if isTeamManager(teamId) || isSuperAdmin();
    }

    // ── /schedules/{uid} ─────────────────────────────
    match /schedules/{uid} {
      // Owner or their team members can read
      allow read:   if isOwner(uid) || isAdmin() ||
        // Team members can read their manager's schedule
        (isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == uid);
      // Only owner can write their schedule
      allow write:  if isOwner(uid);
    }

    // ── /notes/{uid} ─────────────────────────────────
    match /notes/{uid} {
      // Notes are strictly private — owner only
      allow read, write: if isOwner(uid);
    }

    // ── /requests/{requestId} ────────────────────────
    match /requests/{requestId} {
      // Collaborator can create and read their own requests
      allow create: if isAuthenticated() &&
        request.resource.data.collaboratorId == request.auth.uid;
      allow read:   if isAuthenticated() && (
        resource.data.collaboratorId == request.auth.uid ||
        isTeamManager(resource.data.teamId) ||
        isAdmin()
      );
      // Only team manager or admin can update (approve/reject)
      allow update: if (
        isAuthenticated() && isTeamManager(resource.data.teamId)
      ) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── /admins/{uid} ─────────────────────────────────
    match /admins/{uid} {
      // Only admins can read admin list
      allow read:   if isAdmin();
      // Only superadmin can write admin records
      allow write:  if isSuperAdmin();
    }

    // ── /admin_audit/{logId} ─────────────────────────
    match /admin_audit/{logId} {
      allow read:   if isAdmin();
      // Admins can create logs but never edit/delete them
      allow create: if isAdmin();
      allow update, delete: if false; // Immutable audit trail
    }

    // ── /system/{docId} ──────────────────────────────
    match /system/{docId} {
      // Anyone can read system notices
      allow read: if isAuthenticated();
      // Only superadmin can write system config
      allow write: if isSuperAdmin();
    }

    // ── Deny all other access ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
